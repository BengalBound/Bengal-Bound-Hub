# ─── BengalBound-HUB environment template ────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
#
# Required vars (app will refuse to start if missing):
#   SECRET_KEY
#
# Optional in development (leave blank — features degrade gracefully):
#   FACEBOOK_WEBHOOK_VERIFY_TOKEN, LITELLM_MASTER_KEY, GROQ_API_KEY,
#   OPENAI_API_KEY, OPENROUTER_API_KEY, DATABASE_URL

# ── Django core ───────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

DEBUG=True

# Comma-separated list (blank = empty in production, localhost added automatically in dev)
ALLOWED_HOSTS=

# ── Email (SMTP) — only used when DEBUG=False ─────────────────────────────────
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=2525

# ── Serea AI ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Required — must match what you set in the Facebook Developer Console webhook config
FACEBOOK_WEBHOOK_VERIFY_TOKEN=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Only needed when your domain can't use build_absolute_uri (e.g. ngrok)
FACEBOOK_OAUTH_REDIRECT_URI=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (Brevo SMTP — free 300 emails/day) ─────────────────────────────────
# Sign up at https://app.brevo.com → Transactional → SMTP & API → SMTP Keys
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-brevo-smtp-key
EMAIL_PORT=587
DEFAULT_FROM_EMAIL=BengalBound <noreply@bengalbound.com>

# ── Payments (NowPayments) ───────────────────────────────────────────────────
# Sign up free: https://nowpayments.io  |  Sandbox: https://sandbox.nowpayments.io
# Webhook URL to register in NowPayments dashboard: https://app.bengalbound.com/nowpayments/webhook/
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_URL=https://api-sandbox.nowpayments.io/v1

# ── LiteLLM ───────────────────────────────────────────────────────────────────
LITELLM_BASE_URL=https://ai.neurolinkit.com/v1
LITELLM_MASTER_KEY=

# ── Field encryption (django-encrypted-model-fields) ─────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ── Celery ────────────────────────────────────────────────────────────────────
# Dev: memory:// (no broker needed)
# Production: redis://127.0.0.1:6379/0
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://

# ── Database ─────────────────────────────────────────────────────────────────
# Dev: leave blank — SQLite is used automatically
# Production: postgres://user:password@host:5432/bengalbound
DATABASE_URL=

# ── Proxy / network ───────────────────────────────────────────────────────────
# Comma-separated IPs of trusted reverse proxies (empty = direct connection only)
TRUSTED_PROXIES=
