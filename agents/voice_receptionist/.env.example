# ============================================================
# Bengal Bound — Voice Receptionist Module
# .env.example — copy to .env and fill in all values
# ============================================================

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX          # Your Twilio phone number

# --- Google Cloud / Gemini ---
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Google Calendar OAuth (for Admin calendar connect flow) ---
GOOGLE_CALENDAR_CLIENT_ID=XXXXXXXX.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXX
GOOGLE_CALENDAR_REDIRECT_URI=https://yourapp.com/api/v1/voice/calendar/connect/

# --- Firebase ---
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json

# --- Encryption (calendar OAuth token at rest) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CALENDAR_FERNET_KEY=your_generated_fernet_key_here

# --- Gmail SMTP (Google One Pro) ---
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx    # Google Account → Security → App Passwords

# --- App Config ---
DEFAULT_FORWARDING_NUMBER=+1XXXXXXXXXX    # Fallback number when no business forwarding set
BUSINESS_OWNER_EMAIL=owner@business.com   # Receives weekly reports + missed call alerts
DEBUG=True
SECRET_KEY=your-django-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
